{
  "name": "apex-agent",
  "displayName": "ApexAgent",
  "description": "Autonomous self-learning AI coding assistant with multi-provider, sub-agent orchestration, and auto-skill system",
  "version": "0.1.0",
  "publisher": "apex-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jahdaganj03ki-wq/VSChat.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Chat",
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "copilot",
    "code",
    "agent",
    "multi-provider",
    "self-learning"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onChat:apexAgent",
    "onCommand:apex.chat.open",
    "onCommand:apex.chat.toggle",
    "onCommand:apex.mode.switch",
    "onCommand:apex.settings.open",
    "onCommand:apex.history.show",
    "onCommand:apex.skills.show"
  ],
  "contributes": {
    "commands": [
      {
        "command": "apex.chat.open",
        "title": "ApexAgent: Open Chat"
      },
      {
        "command": "apex.chat.toggle",
        "title": "ApexAgent: Toggle Chat Panel"
      },
      {
        "command": "apex.mode.switch",
        "title": "ApexAgent: Switch Mode (Plan/Code)"
      },
      {
        "command": "apex.mode.custom",
        "title": "ApexAgent: Create Custom Mode"
      },
      {
        "command": "apex.settings.open",
        "title": "ApexAgent: Open Settings"
      },
      {
        "command": "apex.history.show",
        "title": "ApexAgent: Show Conversation History"
      },
      {
        "command": "apex.history.export",
        "title": "ApexAgent: Export History"
      },
      {
        "command": "apex.skills.show",
        "title": "ApexAgent: Show Installed Skills"
      },
      {
        "command": "apex.persona.switch",
        "title": "ApexAgent: Switch Persona"
      },
      {
        "command": "apex.learning.export",
        "title": "ApexAgent: Export Knowledge Database"
      },
      {
        "command": "apex.learning.reset",
        "title": "ApexAgent: Reset Learned Knowledge"
      },
      {
        "command": "apex.about",
        "title": "ApexAgent: About"
      }
    ],
    "keybindings": [
      {
        "command": "apex.chat.open",
        "key": "ctrl+shift+a",
        "when": "editorFocus"
      },
      {
        "command": "apex.mode.switch",
        "key": "ctrl+shift+m",
        "when": "editorFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "apex.chat.open",
          "group": "apex"
        }
      ],
      "editor/title/context": [
        {
          "command": "apex.chat.open",
          "group": "apex"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-sidebar",
          "title": "ApexAgent",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "apex-sidebar": [
        {
          "type": "tree",
          "id": "apex-history",
          "name": "Conversation History"
        },
        {
          "type": "tree",
          "id": "apex-skills",
          "name": "Skills"
        },
        {
          "type": "tree",
          "id": "apex-subagents",
          "name": "Sub-Agents"
        }
      ]
    },
    "configuration": {
      "title": "ApexAgent",
      "properties": {
        "apex.chat.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 8,
          "maximum": 48,
          "description": "Font size for chat messages"
        },
        "apex.chat.theme": {
          "type": "string",
          "default": "dark",
          "enum": [
            "dark",
            "light",
            "high-contrast",
            "custom"
          ],
          "description": "Chat UI theme"
        },
        "apex.chat.showLineNumbers": {
          "type": "boolean",
          "default": true,
          "description": "Show line numbers in code blocks"
        },
        "apex.chat.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scroll to new messages"
        },
        "apex.chat.enterToSend": {
          "type": "boolean",
          "default": true,
          "description": "Enter sends message (Ctrl+Enter for new line)"
        },
        "apex.modes.default": {
          "type": "string",
          "default": "plan",
          "enum": [
            "plan",
            "code"
          ],
          "description": "Default mode on extension start"
        },
        "apex.modes.autoSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Auto-switch to code mode after plan creation"
        },
        "apex.modes.showConfirmation": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before mode switch"
        },
        "apex.modes.custom": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "prompt": {
                "type": "string"
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "description": "Custom mode definitions"
        },
        "apex.modes.rememberLast": {
          "type": "boolean",
          "default": true,
          "description": "Remember last active mode across sessions"
        },
        "apex.provider": {
          "type": "string",
